# Optional HTTP proxy for cloning the framework submodules.
# scripts/add-submodules.sh tries a DIRECT github.com connection first;
# this proxy is only used if direct fails.
# Copy to .env and fill in your proxy, OR run: ./scripts/add-submodules.sh --proxy http://127.0.0.1:7890
# (.env is gitignored and never uploaded.)
HTTP_PROXY=
HTTPS_PROXY=
